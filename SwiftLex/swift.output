   38     | expr . '&' expr
   39     | expr . '|' expr
   40     | expr . '^' expr
   41     | expr . OP_LOG_AND expr
   42     | expr . OP_LOG_OR expr
   43     | expr . OP_LSHIFT expr
   44     | expr . OP_RSHIFT expr
   45     | expr . OP_CLOSED_RANGE expr
   46     | expr . OP_HALF_OPEN_RANGE expr
   47     | expr . OP_NIL_COALESCE expr
   48     | expr . IS type
   49     | expr . AS type
   50     | expr . AS '?' type
   51     | expr . AS '!' type
   52     | expr . '?' expr ':' expr
   52     | expr '?' expr ':' expr .

    AS                  shift, and go to state 18
    IS                  shift, and go to state 19
    OP_LSHIFT           shift, and go to state 20
    OP_RSHIFT           shift, and go to state 21
    OP_EQ               shift, and go to state 22
    OP_LTE              shift, and go to state 23
    OP_GTE              shift, and go to state 24
    OP_NEQ              shift, and go to state 25
    OP_LOG_AND          shift, and go to state 26
    OP_LOG_OR           shift, and go to state 27
    OP_NIL_COALESCE     shift, and go to state 28
    OP_CLOSED_RANGE     shift, and go to state 29
    OP_HALF_OPEN_RANGE  shift, and go to state 30
    '?'                 shift, and go to state 31
    '|'                 shift, and go to state 32
    '^'                 shift, and go to state 33
    '&'                 shift, and go to state 34
    '<'                 shift, and go to state 35
    '>'                 shift, and go to state 36
    '+'                 shift, and go to state 37
    '-'                 shift, and go to state 38
    '*'                 shift, and go to state 39
    '/'                 shift, and go to state 40
    '%'                 shift, and go to state 41

    $default  reduce using rule 52 (expr)
