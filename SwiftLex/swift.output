Rules useless in grammar

   54 varIdWithComma: ID ','

   55 varIdWithCommaList: varIdWithComma
   56                   | varIdWithCommaList varIdWithComma

   57 varIdWithType: ID ':' type

   58 varIdListWithType: varIdWithCommaList varIdWithType
   59                  | varIdWithType

   60 varList: varIdWithType '=' expr
   61        | ID '=' expr
   62        | varIdListWithType

   63 varVarList: varList
   64           | varVarList ',' varList

   65 varDeclaration: VAR varVarList
   66               | LET varVarList


Grammar

    0 $accept: program $end

    1 program: expr

    2 type: TYPE_BOOL
    3     | TYPE_STRING
    4     | TYPE_CHARACTER
    5     | TYPE_INT8
    6     | TYPE_INT16
    7     | TYPE_INT32
    8     | TYPE_INT64
    9     | TYPE_INT
   10     | TYPE_UINT8
   11     | TYPE_UINT16
   12     | TYPE_UINT32
   13     | TYPE_UINT64
   14     | TYPE_UINT
   15     | TYPE_FLOAT
   16     | TYPE_FLOAT80
   17     | TYPE_DOUBLE

   18 expr: LITERAL_INT
   19     | LITERAL_FLOAT
   20     | LITERAL_STRING
   21     | ID
   22     | TRUE
   23     | FALSE
   24     | '~' expr
   25     | '!' expr
   26     | '-' expr
   27     | expr '+' expr
   28     | expr '-' expr
   29     | expr '/' expr
   30     | expr '*' expr
   31     | expr '%' expr
   32     | expr '<' expr
   33     | expr '>' expr
   34     | expr OP_GTE expr
   35     | expr OP_LTE expr
   36     | expr OP_EQ expr
   37     | expr OP_NEQ expr
   38     | expr '&' expr
   39     | expr '|' expr
   40     | expr '^' expr
   41     | expr OP_LOG_AND expr
   42     | expr OP_LOG_OR expr
   43     | expr OP_LSHIFT expr
   44     | expr OP_RSHIFT expr
   45     | expr OP_CLOSED_RANGE expr
   46     | expr OP_HALF_OPEN_RANGE expr
   47     | expr OP_NIL_COALESCE expr
   48     | expr IS type
   49     | expr AS type
   50     | expr AS '?' type
   51     | expr AS '!' type
   52     | expr '?' expr ':' expr
   53     | '(' expr ')'


